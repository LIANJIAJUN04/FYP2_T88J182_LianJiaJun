# Local InfluxDB (Docker — see docker-compose.yml)
LOCAL_INFLUX_URL=http://localhost:8087
LOCAL_INFLUX_TOKEN=your-local-influx-token
LOCAL_INFLUX_ORG=your-org-name
LOCAL_INFLUX_BUCKET=health_local

# InfluxDB Cloud (Singapore region — cloud2.influxdata.com)
CLOUD_INFLUX_URL=https://ap-southeast-1-1.aws.cloud2.influxdata.com
CLOUD_INFLUX_TOKEN=your-cloud-influx-token
CLOUD_INFLUX_ORG=your-cloud-org-name
CLOUD_INFLUX_BUCKET=health_cloud

# Supabase
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# Shared secrets
NURSE_PASSWORD=your-shared-nurse-password
DEVICE_SECRET=your-shared-esp32-secret
