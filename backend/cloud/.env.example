# InfluxDB Cloud (Singapore region — cloud2.influxdata.com)
CLOUD_INFLUX_URL=https://ap-southeast-1-1.aws.cloud2.influxdata.com
CLOUD_INFLUX_TOKEN=your-cloud-influx-token
CLOUD_INFLUX_ORG=your-cloud-org-name
CLOUD_INFLUX_BUCKET=health_cloud

# Supabase
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# CORS — comma-separated list of allowed origins (set to Vercel domain on Railway)
ALLOWED_ORIGINS=http://localhost:3001,https://your-vercel-app.vercel.app

# Railway deployment URL (production)
# RAILWAY_URL=https://medisync-cloud-api-production.up.railway.app